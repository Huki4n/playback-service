### Variables
@host = http://localhost:8080
@userId = user-123
@trackId = track-456
@deviceId = device-mobile-1
@deviceId2 = device-desktop-2

### ──────────────────────────────────────────
### Infrastructure
### ──────────────────────────────────────────

### Healthz
GET {{host}}/healthz

> {%
  client.test("status 200", function() {
    client.assert(response.status === 200, "got " + response.status);
  });
  client.test("status ok", function() {
    client.assert(response.body.status === "ok", "got " + response.body.status);
  });
%}

###

### Readyz
GET {{host}}/readyz

> {%
  client.test("status 200", function() {
    client.assert(response.status === 200, "got " + response.status);
  });
  client.test("status ready", function() {
    client.assert(response.body.status === "ready", "got " + response.body.status);
  });
%}

