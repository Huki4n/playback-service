### Metrics (Prometheus)
GET {{host}}/metrics

> {%
  client.test("status 200", function() {
    client.assert(response.status === 200, "got " + response.status);
  });
  client.test("content-type text", function() {
    client.assert(response.contentType.mimeType === "text/plain", "got " + response.contentType.mimeType);
  });
%}

###

### Example endpoint
GET {{host}}/api/v1/example

> {%
  client.test("status 200", function() {
    client.assert(response.status === 200, "got " + response.status);
  });
  client.test("has message", function() {
    client.assert(typeof response.body.message === "string", "no message field");
  });
%}

